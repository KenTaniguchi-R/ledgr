# Required
ENCRYPTION_KEY=           # 32-byte hex string: openssl rand -hex 32
AUTH_SECRET=              # Session secret: openssl rand -base64 32
DATABASE_PATH=./data/ledgr.db
BETTER_AUTH_URL=http://localhost:3000

# Plaid (optional — app works without it via CSV import)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox         # sandbox | development | production
PLAID_SYNC_MODE=poll      # poll | webhook
PLAID_WEBHOOK_URL=        # Only needed if PLAID_SYNC_MODE=webhook

# AI (optional — BYOK, user configures in settings)
# No server-side AI keys needed; users provide their own via the settings UI
